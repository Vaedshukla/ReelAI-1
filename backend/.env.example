# ──────────────────────────────────────────────────────────────────────────────
# ReelIntel Environment Configuration
# Copy this file to .env and fill in your API keys.
# NEVER commit .env to git — it's already in .gitignore.
# ──────────────────────────────────────────────────────────────────────────────

# ── Required API Keys ─────────────────────────────────────────────────────────

# Get free Groq API key → https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
# Get free Serper key → https://serper.dev (100 free searches/month)
SERPER_API_KEY=your_serper_api_key_here

# ── Server ────────────────────────────────────────────────────────────────────

# Host to bind to (0.0.0.0 for containers, 127.0.0.1 for local)
# HOST=0.0.0.0

# Port to listen on (Railway sets this automatically)
# PORT=8000

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
# LOG_LEVEL=INFO

# ── Optional: LLM Settings ────────────────────────────────────────────────────

# Groq model to use. Options:
#   llama-3.1-8b-instant   (fastest, default)
#   llama-3.1-70b-versatile (smarter, slower)
#   mixtral-8x7b-32768     (great for structured JSON)
# GROQ_MODEL=llama-3.1-8b-instant

# LLM temperature (0 = deterministic, 1 = creative)
# GROQ_TEMPERATURE=0

# Max characters of reel text to send to LLM
# LLM_MAX_CONTEXT_CHARS=8000

# Max tokens for LLM response
# LLM_MAX_TOKENS=512

# ── Optional: Whisper Settings ────────────────────────────────────────────────

# Whisper model size. Options: tiny | base | small | medium | large
# Larger = more accurate but slower + more VRAM
# WHISPER_MODEL_SIZE=base

# ── Optional: OCR Settings ───────────────────────────────────────────────────

# Comma-separated EasyOCR language codes (e.g. "en,hi" for English + Hindi)
# LANGUAGES list: https://www.jaided.ai/easyocr/
# OCR_LANGUAGES=en

# OCR confidence threshold 0.0–1.0 (lower = more text, more noise)
# OCR_CONFIDENCE_THRESHOLD=0.4

# ── Optional: Audio Extraction ────────────────────────────────────────────────

# Sample rate for audio extraction (Hz)
# AUDIO_SAMPLE_RATE=16000

# Number of audio channels (1 = mono, 2 = stereo)
# AUDIO_CHANNELS=1

# ── Optional: Device ──────────────────────────────────────────────────────────

# Device for Whisper + EasyOCR: auto | cuda | cpu
# auto detects GPU automatically (recommended)
# DEVICE_PREFERENCE=auto

# ── Optional: Frame Extraction ────────────────────────────────────────────────

# How many seconds between extracted frames
# FRAME_INTERVAL_SEC=2

# ── Optional: Search ─────────────────────────────────────────────────────────

# Number of web search results to return (max 100)
# SEARCH_NUM_RESULTS=10

# ── Optional: Storage ─────────────────────────────────────────────────────────

# Directory for temporary downloads (relative to backend/)
# REELAI_DOWNLOADS_DIR=downloads

# Delete video/audio/frames after processing (saves disk space)
# CLEANUP_AFTER_PROCESSING=true

# ── Optional: CORS ────────────────────────────────────────────────────────────

# Comma-separated allowed origins (use specific domains in production)
# CORS_ORIGINS=https://yourdomain.com
